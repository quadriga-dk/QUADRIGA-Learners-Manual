        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Book_Template/#chapter_0_objective_0" />
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Book_Template/#chapter_0_objective_1" />
        <schema:name>Inhaltskapitel</schema:name>
        <schema:teaches>Sie kennen die Bestandteile des Templates und können es für Ihre Bedürfnisse nutzen.</schema:teaches>
        <schema:timeRequired>PT1H</schema:timeRequired>
        <schema:url rdf:resource="https://quadriga-dk.github.io/Book_Template/inhaltskapitel/einleitung.html" />
      </schema:LearningResource>
    </schema:hasPart>
